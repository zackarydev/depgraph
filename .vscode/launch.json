    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Image",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/codegen/imagegen.mjs",
            "args": [
                "--size", "32",
                "--url", "./image.png",
                "--out", "./runtime/image.csv"
            ]
        }
    ]
}