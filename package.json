{
  "name": "depgraph",
  "version": "1.0.0",
  "description": "[Videos](https://youtu.be/slwxspOzzK0)",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start":        "node depgraph-server.mjs --port 3000 & open 'http://localhost:3000/?stream'",
    "image":        "node depgraph-server.mjs --port 3000 --history runtime/image.csv & open 'http://localhost:3000/?stream'",
    "readme":       "node depgraph-server.mjs --port 3000 --history runtime/history.readme.csv & open 'http://localhost:3000/?stream'",
    "demo":         "node depgraph-server.mjs --port 3000 & sleep 1 && open 'http://localhost:3000/'",
    "demo:fractal": "node depgraph-server.mjs --port 3000 & sleep 1 && open 'http://localhost:3000/?demo=fractal'",
    "gen":          "node codegen/graphgen.mjs --out runtime/history.csv",
    "gen:readme":   "node codegen/readmegen.mjs --out runtime/history.readme.csv",
    "scan":         "node codegen/repo-scanner.mjs . --out runtime/history.csv",
    "watch":        "node codegen/watcher.mjs --root . --out runtime/history.csv",
    "test":         "node --test --test-reporter=spec --test-concurrency=1 test/*.test.mjs",
    "test:ui":      "npx playwright test --headed"
  },
  "keywords": [
    "hypergraph"
  ],
  "author": "zackary.dev",
  "license": "ISC",
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "jimp": "^1.6.1",
    "mdast-util-from-markdown": "^2.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
